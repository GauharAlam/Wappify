NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Optional but recommended so Clerk uses your custom auth routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

DATABASE_URL="postgresql://user:password@host:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# Existing integrations used by the dashboard.
WHATSAPP_VERIFY_TOKEN=replace_me
GEMINI_API_KEY=replace_me
RAZORPAY_PLATFORM_KEY_ID=replace_me
RAZORPAY_PLATFORM_KEY_SECRET=replace_me
RAZORPAY_PLAN_STARTER=plan_replace_me
RAZORPAY_PLAN_PRO=plan_replace_me
RAZORPAY_BILLING_WEBHOOK_SECRET=replace_me
