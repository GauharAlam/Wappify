generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Merchant {
  id                  String    @id @default(uuid())
  name                String
  whatsappNumber      String    @unique
  twilioAccountSid    String?
  twilioAuthToken     String?
  razorpayKeyId       String?
  razorpayKeySecret   String?
  upiId               String?           // Direct UPI ID (e.g. merchant@upi) — zero-cost alternative to Razorpay
  aiContext           String?   @db.Text

  userId              String?
  user                User?     @relation(fields: [userId], references: [id])

  products            Product[]
  orders              Order[]
  subscription        Subscription?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// Subscription Billing
// ─────────────────────────────────────────────

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PENDING
  HALTED
  CANCELLED
  EXPIRED
  PAUSED
}

enum PlanTier {
  STARTER
  PRO
  ENTERPRISE
}

model Subscription {
  id                      String             @id @default(uuid())
  merchantId              String             @unique
  merchant                Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  planTier                PlanTier           @default(STARTER)
  status                  SubscriptionStatus @default(CREATED)

  // Razorpay identifiers
  razorpaySubscriptionId  String?            @unique
  razorpayPlanId          String?
  razorpayCustomerId      String?

  // Billing cycle
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?

  // Trial
  trialEndsAt             DateTime?

  cancelledAt             DateTime?

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  merchants     Merchant[]
  role          UserRole  @default(USER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id        String   @id @default(uuid())
  waId      String   @unique
  name      String?

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  imageUrl    String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)

  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                String      @id @default(uuid())
  merchantId        String
  merchant          Merchant    @relation(fields: [merchantId], references: [id])
  customerId        String
  customer          Customer    @relation(fields: [customerId], references: [id])

  status            OrderStatus @default(PENDING)
  totalAmount       Decimal     @db.Decimal(10, 2)

  razorpayOrderId   String?     @unique
  razorpayPaymentId String?     @unique

  items             OrderItem[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])

  quantity    Int
  priceAtTime Decimal @db.Decimal(10, 2)
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model WebhookEvent {
  id        String    @id @default(uuid())
  payload   Json
  status    JobStatus @default(PENDING)
  error     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// Chat Message Log (for CRM)
// ─────────────────────────────────────────────

model ChatMessage {
  id           String   @id @default(uuid())
  merchantId   String
  customerWaId String
  sender       String   // "customer" or "bot"
  message      String   @db.Text
  createdAt    DateTime @default(now())

  @@index([merchantId, customerWaId])
  @@index([merchantId, createdAt])
}
