generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Multi-Tenant: Organization (formerly Merchant)
// ─────────────────────────────────────────────

model Organization {
  id                 String          @id @default(uuid())
  name               String
  slug               String          @unique @default(cuid())
  whatsappNumber     String          @unique
  storeCode          String          @unique @default(cuid())
  whatsappConnected  Boolean         @default(false)
  razorpayKeyId      String?
  razorpayKeySecret  String?
  upiId              String?
  aiContext           String?
  timezone           String          @default("Asia/Kolkata")
  logoUrl            String?
  businessHoursSchedule Json?
  onboardingCompleted  Boolean         @default(false)
  selectedTemplate     String?
  geminiTokensUsed   Int             @default(0)
  messagesSent       Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  members            OrgMember[]
  orders             Order[]
  products           Product[]
  subscription       Subscription?
  conversations      Conversation[]
  messages           Message[]
  tags               Tag[]
  auditLogs          AuditLog[]
  contacts           Contact[]
  automationRules    AutomationRule[]

  // @deprecated — kept for backward compat, use OrgMember instead
  twilioAccountSid   String?
  twilioAuthToken    String?

  @@index([storeCode])
  @@index([slug])
}

// ─────────────────────────────────────────────
// Organization Members (User ↔ Organization)
// ─────────────────────────────────────────────

model OrgMember {
  id             String       @id @default(uuid())
  orgId          String
  userId         String?
  email          String
  role           OrgRole      @default(AGENT)
  isActive       Boolean      @default(true)
  invitedAt      DateTime     @default(now())
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedConvos Conversation[] @relation("AssignedAgent")
  sentMessages   Message[]    @relation("SenderMember")

  @@unique([orgId, email])
  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

enum OrgRole {
  OWNER
  ADMIN
  AGENT
}

// ─────────────────────────────────────────────
// Users (Auth — linked via Clerk)
// ─────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole    @default(USER)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  memberships   OrgMember[]
  auditLogs     AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Subscription / Billing
// ─────────────────────────────────────────────

model Subscription {
  id                     String             @id @default(uuid())
  orgId                  String             @unique
  planTier               PlanTier           @default(STARTER)
  status                 SubscriptionStatus @default(CREATED)
  paymentMethod          String             @default("RAZORPAY")
  upiTransactionRef      String?            @unique
  razorpaySubscriptionId String?            @unique
  razorpayPlanId         String?
  razorpayCustomerId     String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialEndsAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  org                    Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Contacts (Customers on WhatsApp)
// ─────────────────────────────────────────────

model Contact {
  id        String         @id @default(uuid())
  orgId     String
  waId      String
  name      String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orders        Order[]
  conversations Conversation[]

  @@unique([orgId, waId])
  @@index([orgId])
  @@index([waId])
}

// ─────────────────────────────────────────────
// Conversations (Thread per Contact per Org)
// ─────────────────────────────────────────────

model Conversation {
  id                 String             @id @default(uuid())
  orgId              String
  contactId          String
  status             ConversationStatus @default(OPEN)
  assignedToId       String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadCount        Int                @default(0)
  isEscalated        Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact    Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo OrgMember?       @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   Message[]
  tags       ConversationTag[]

  @@unique([orgId, contactId])
  @@index([orgId, status])
  @@index([orgId, lastMessageAt])
  @@index([assignedToId])
}

enum ConversationStatus {
  OPEN
  ASSIGNED
  RESOLVED
  CLOSED
}

// ─────────────────────────────────────────────
// Messages (Individual chat messages)
// ─────────────────────────────────────────────

model Message {
  id                String           @id @default(uuid())
  orgId             String
  conversationId    String
  direction         MessageDirection
  content           String
  type              MessageType      @default(TEXT)
  mediaUrl          String?
  senderMemberId    String?
  whatsappMessageId String?
  createdAt         DateTime         @default(now())

  // Relations
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderMember   OrgMember?    @relation("SenderMember", fields: [senderMemberId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([orgId, createdAt])
  @@index([whatsappMessageId])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
}

// ─────────────────────────────────────────────
// Tags (for Conversations)
// ─────────────────────────────────────────────

model Tag {
  id        String            @id @default(uuid())
  orgId     String
  name      String
  color     String            @default("#6366f1")
  createdAt DateTime          @default(now())

  org           Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]
  automationRules AutomationRule[]

  @@unique([orgId, name])
  @@index([orgId])
}

model ConversationTag {
  conversationId String
  tagId          String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
}

// ─────────────────────────────────────────────
// Audit Logs
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([orgId, entity])
}

// ─────────────────────────────────────────────
// Products
// ─────────────────────────────────────────────

model Product {
  id          String      @id @default(uuid())
  orgId       String
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  currency    String      @default("INR")
  imageUrl    String?
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  cartItems   CartItem[]
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Orders & Cart
// ─────────────────────────────────────────────

model Order {
  id                String      @id @default(uuid())
  orgId             String
  contactId         String
  status            OrderStatus @default(PENDING)
  totalAmount       Decimal     @db.Decimal(10, 2)
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?     @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  contact           Contact     @relation(fields: [contactId], references: [id])
  org               Organization @relation(fields: [orgId], references: [id])
  items             OrderItem[]
}

model Cart {
  id         String     @id @default(uuid())
  orgId      String
  contactId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]

  @@unique([orgId, contactId])
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  priceAtTime Decimal @db.Decimal(10, 2)
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// Webhook Queue (Background Processing)
// ─────────────────────────────────────────────

model WebhookEvent {
  id        String    @id @default(uuid())
  payload   Json
  status    JobStatus @default(PENDING)
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// Platform Settings (Global Admin)
// ─────────────────────────────────────────────

model PlatformSettings {
  id         String   @id @default("global")
  adminUpiId String?
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PENDING
  HALTED
  CANCELLED
  EXPIRED
  PAUSED
}

enum PlanTier {
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  USER
  ADMIN
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// Automation Rules
// ─────────────────────────────────────────────

model AutomationRule {
  id           String      @id @default(uuid())
  orgId        String
  name         String
  isActive     Boolean     @default(true)
  priority     Int         @default(0)
  trigger      AutoTrigger
  keywords     String[]    @default([])
  matchMode    MatchMode   @default(EXACT)
  action       AutoAction
  responseText String?
  tagId        String?
  source       String      @default("user")
  templateId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tag          Tag?         @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@index([orgId, isActive, priority])
  @@index([orgId, templateId])
  @@unique([orgId, templateId, name])
}

enum AutoTrigger {
  KEYWORD
  FIRST_MESSAGE
  OUTSIDE_HOURS
  MEDIA_RECEIVED
  ALL_MESSAGES
}

enum MatchMode {
  EXACT
  CONTAINS
  STARTS_WITH
}

enum AutoAction {
  SEND_TEXT
  SEND_CATALOG
  SEND_GREETING
  FORWARD_TO_AI
  ESCALATE_TO_HUMAN
  SET_TAG
}
